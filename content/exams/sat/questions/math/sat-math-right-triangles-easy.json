    "subskill": "pythagorean",
    "prompt": "A right triangle has one leg of length 9 and a hypotenuse of length 41. What is the length of the other leg?",
    "choices": [
      {
        "id": "A",
        "text": "41",
        "rationale": "Off by one; recompute c² − a²."
      },
      {
        "id": "B",
        "text": "40",
        "rationale": "Correct."
      },
      {
        "id": "C",
        "text": "50",
        "rationale": "Add/subtract under the square root, not outside it."
      },
      {
        "id": "D",
        "text": "32",
        "rationale": "Subtracting the lengths is not the Pythagorean theorem."
      }
    ],
    "correct_choice": "B",
    "explanation": "By the Pythagorean theorem, leg = √(c² − a²) = √(1681 − 81) = √1600 = 40.",
    "estimated_time_seconds": 85,
    "tags": [
      "geometry",
      "right-triangle"
    ],
    "answer_verification": "sides 9,40,41"
  },
