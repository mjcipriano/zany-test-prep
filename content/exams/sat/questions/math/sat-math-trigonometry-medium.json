    "subskill": "sohcahtoa",
    "prompt": "In a right triangle, cos θ = 12/13. If the hypotenuse has length 39, what is the length of the side adjacent to θ?",
    "choices": [
      {
        "id": "A",
        "text": "15",
        "rationale": "That is the opposite side (from sin θ), not the adjacent."
      },
      {
        "id": "B",
        "text": "39",
        "rationale": "That is the hypotenuse, not the adjacent side."
      },
      {
        "id": "C",
        "text": "36",
        "rationale": "Correct."
      },
      {
        "id": "D",
        "text": "12",
        "rationale": "Scale up by the hypotenuse; don't use the ratio's numerator alone."
      }
    ],
    "correct_choice": "C",
    "explanation": "cos θ = adjacent/hypotenuse, so adjacent = cos θ × hypotenuse = 12/13 × 39 = 36.",
    "estimated_time_seconds": 90,
    "tags": [
      "trigonometry"
    ],
    "stimulus": {
