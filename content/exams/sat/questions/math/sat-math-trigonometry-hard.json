    "question_type": "multiple_choice",
    "subskill": "sohcahtoa",
    "prompt": "In a right triangle, sin θ = 20/29. What is cos θ?",
    "choices": [
      {
        "id": "A",
        "text": "21/29",
        "rationale": "Correct."
      },
      {
        "id": "B",
        "text": "20/21",
        "rationale": "That is tan θ (opposite/adjacent)."
      },
      {
        "id": "C",
        "text": "20/29",
        "rationale": "That is sin θ again, not cos θ."
      },
      {
        "id": "D",
        "text": "29/21",
        "rationale": "This inverts the cosine ratio."
      }
    ],
    "correct_choice": "A",
    "explanation": "With opposite 20 and hypotenuse 29, the adjacent side is 21 (since 20²+21²=29²). So cos θ = adjacent/hypotenuse = 21/29.",
    "estimated_time_seconds": 95,
    "tags": [
      "trigonometry"
    ],
    "stimulus": {
      "type": "figure",
      "figure": {
        "kind": "right_triangle",
        "caption": "Right triangle",
        "angle": "θ",
        "labels": {
          "a": "20",
          "b": "21",
          "c": "29"
        }
      }
    },
    "answer_verification": "cos=21/29"
  },
