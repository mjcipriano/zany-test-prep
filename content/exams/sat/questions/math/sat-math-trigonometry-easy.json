        "text": "15/25",
        "rationale": "That ratio is sine (opposite/hypotenuse)."
      },
      {
        "id": "B",
        "text": "15/20",
        "rationale": "That ratio is tangent (opposite/adjacent)."
      },
      {
        "id": "C",
        "text": "25/20",
        "rationale": "This inverts the cosine ratio."
      },
      {
        "id": "D",
        "text": "20/25",
        "rationale": "Correct."
      }
    ],
    "correct_choice": "D",
    "explanation": "cos θ = adjacent/hypotenuse = 20/25.",
