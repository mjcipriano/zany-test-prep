    "subskill": "pythagorean",
    "prompt": "A right triangle has one leg of length 20 and a hypotenuse of length 29. What is the length of the other leg?",
    "choices": [
      {
        "id": "A",
        "text": "9",
        "rationale": "Subtracting the lengths is not the Pythagorean theorem."
      },
      {
        "id": "B",
        "text": "21",
        "rationale": "Correct."
      },
      {
        "id": "C",
        "text": "49",
        "rationale": "Add/subtract under the square root, not outside it."
      },
      {
        "id": "D",
        "text": "22",
        "rationale": "Off by one; recompute c² − a²."
      }
    ],
    "correct_choice": "B",
    "explanation": "By the Pythagorean theorem, leg = √(c² − a²) = √(841 − 400) = √441 = 21.",
    "estimated_time_seconds": 85,
