    "title": "Percentages and Ratios (Hard)",
    "body": "A percent is a part out of 100. To find a percent of a number, multiply by the percent over 100. Percent change is the difference divided by the original amount, times 100.",
    "key_points": [
      "x% of n = (x/100)·n.",
      "Percent change = (new − old)/old × 100.",
      "Always divide by the original value for percent change."
    ],
    "worked_example": "20% of 50 = 0.20·50 = 10."
  },
