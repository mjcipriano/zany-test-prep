  "teaching_card": {
    "title": "Exponential Growth (Medium)",
    "body": "In exponential growth a quantity is multiplied by the same factor each period: value = start × factor^periods. This grows far faster than adding the same amount each time (linear growth).",
    "key_points": [
      "Multiply, don't add, each period.",
      "value = start × factor^time.",
      "Doubling = ×2 each period."
    ],
    "worked_example": "5 cells doubling for 3 hours: 5×2³ = 40."
  },
