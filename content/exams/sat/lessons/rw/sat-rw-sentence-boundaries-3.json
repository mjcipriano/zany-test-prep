  "teaching_card": {
    "title": "Sentence Boundaries (Level 3)",
    "body": "An independent clause can stand alone as a sentence. Two independent clauses cannot be joined by a comma alone (a comma splice) or by nothing (a run-on). Use a period, a semicolon, or a comma plus a coordinating conjunction.",
    "key_points": [
      "A comma alone can't join two independent clauses.",
      "Use a period or semicolon between independent clauses.",
      "A comma + FANBOYS conjunction also works."
    ]
  },
