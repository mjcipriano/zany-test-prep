  "teaching_card": {
    "title": "Verb Tense and Form (Easy)",
    "body": "Match the verb to the time the sentence describes. Clues like 'last year' signal past, 'every day' or 'currently' signal present, and 'next year' or 'will' signal future. Keep tenses consistent.",
    "key_points": [
      "Let time markers set the tense.",
      "Past: -ed; present: base/-s; future: will + base.",
      "An -ing form alone can't be the main verb."
    ],
    "worked_example": "Last year, the team traveled (not travels) abroad."
  },
