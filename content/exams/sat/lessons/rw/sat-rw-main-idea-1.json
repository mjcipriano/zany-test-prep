  "teaching_card": {
    "title": "Finding the Main Idea",
    "body": "The main idea is the single point a passage is built to make. Look for what every sentence supports, not a small detail. A good summary captures the whole passage without adding outside claims.",
    "key_points": [
      "Ask: what is the passage mostly about?",
      "Avoid choices that are true but too narrow.",
      "Reject choices that go beyond the passage."
    ]
  },
