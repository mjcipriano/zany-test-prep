  "teaching_card": {
    "title": "Pronoun-Antecedent Agreement (Medium)",
    "body": "A pronoun must agree in number with the noun it refers to (its antecedent). A singular antecedent takes a singular pronoun; a plural antecedent takes a plural one.",
    "key_points": [
      "Singular antecedent -> its, his, her.",
      "Plural antecedent -> their.",
      "'it's' = 'it is'; 'they're' = 'they are' (not possessive)."
    ],
    "worked_example": "The company released its (not their) report."
  },
