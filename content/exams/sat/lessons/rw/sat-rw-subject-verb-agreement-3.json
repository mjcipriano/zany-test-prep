  "teaching_card": {
    "title": "Subject-Verb Agreement (Level 3)",
    "body": "A verb must match its subject in number. Ignore words between the subject and verb — especially prepositional phrases — which often hide the true subject and bait you into the wrong number.",
    "key_points": [
      "Find the true subject, ignoring in-between phrases.",
      "Singular subject → singular verb; plural → plural.",
      "Watch indefinite pronouns like 'each' (singular)."
    ]
  },
