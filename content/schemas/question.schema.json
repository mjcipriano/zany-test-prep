{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zanybot.ai/schemas/question.schema.json",
  "title": "Exam Question",
  "description": "Exam-agnostic question item. Used for SAT now; ACT/AP reuse the same shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question_id", "exam_id", "exam_name", "domain", "section", "skill",
    "lesson_id", "difficulty", "question_type", "estimated_time_seconds",
    "prompt", "explanation", "version", "tags"
  ],
  "properties": {
    "question_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "exam_id": { "type": "string", "minLength": 1 },
    "exam_name": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "section": { "type": "string", "minLength": 1 },
    "skill": { "type": "string", "minLength": 1 },
    "subskill": { "type": "string" },
    "lesson_id": { "type": "string", "minLength": 1 },
    "difficulty": { "enum": ["easy", "medium", "hard"] },
    "question_type": {
      "enum": [
        "multiple_choice",
        "student_produced",
        "passage_reading",
        "grammar_editing",
        "data_interpretation",
        "multi_step_math"
      ]
    },
    "estimated_time_seconds": { "type": "integer", "minimum": 10, "maximum": 600 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "stimulus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["passage", "table", "paired_passages"] },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "text_b": { "type": "string" },
        "table": {
          "type": "object",
          "additionalProperties": false,
          "required": ["headers", "rows"],
          "properties": {
            "caption": { "type": "string" },
            "headers": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "rows": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "prompt": { "type": "string", "minLength": 5 },
    "choices": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "rationale"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-F]$" },
          "text": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 3 }
        }
      }
    },
    "correct_choice": { "type": "string", "pattern": "^[A-F]$" },
    "answer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "accepted"],
      "properties": {
        "type": { "enum": ["numeric", "string"] },
        "value": { "type": ["number", "string"] },
        "accepted": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "tolerance": { "type": "number", "minimum": 0 }
      }
    },
    "explanation": { "type": "string", "minLength": 10 },
    "answer_verification": { "type": "string" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "question_type": { "const": "student_produced" } }
      },
      "then": { "required": ["answer"] },
      "else": { "required": ["choices", "correct_choice"] }
    }
  ]
}
